{
  "name": "pi-xai-imagine",
  "version": "0.1.0",
  "description": "Pi extension for xAI image, video, and vision workflows",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "*.ts",
    "tsconfig.json",
    "README.md",
    "assets"
  ],
  "type": "module",
  "scripts": {
    "build": "echo 'nothing to build'",
    "typecheck": "bunx tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware --type-check *.ts",
    "lint:fix": "oxlint --type-aware --type-check --fix *.ts",
    "format": "oxfmt --check *.ts *.md *.json *.yml",
    "format:fix": "oxfmt --write *.ts *.md *.json *.yml",
    "check": "bun run format && bun run lint && bun run typecheck",
    "check:ci": "bun run check",
    "prepare": "lefthook install"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript": "^5.7.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
